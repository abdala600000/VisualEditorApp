<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:m="using:VisualEditor.Toolbox.Outline"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            
             x:Class="VisualEditor.Toolbox.Outline.DocumentOutlineView"
             x:DataType="m:DocumentOutlineViewModel">
     

    <Grid RowDefinitions="Auto, *">
        <TextBox Grid.Row="0" Margin="5" Watermark="Search Elements..." />

        <TreeView Grid.Row="1" 
                  ItemsSource="{Binding Nodes,Mode=TwoWay}" 
                  SelectionMode="Single"
                  SelectionChanged="TreeView_SelectionChanged">
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}" DataType="{x:Type m:ElementNode}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource BoxIcon}" Width="12" Height="12" Foreground="DodgerBlue"/>
                        <TextBlock Text="{Binding Header}" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
