<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:editor="clr-namespace:VisualEditor.CodeEditor;assembly=VisualEditor.CodeEditor"
             xmlns:designer="clr-namespace:VisualEditor.Designer;assembly=VisualEditor.Designer"
             xmlns:vm="clr-namespace:VisualEditorApp.ViewModels.Documents"
             x:Class="VisualEditorApp.Views.Documents.WorkspaceView"
             x:DataType="vm:WorkspaceViewModel"
             x:CompileBindings="False">
    
    <Grid x:Name="MainGrid" RowDefinitions="*, 5, *">
        
        <designer:DesignerSurfaceView x:Name="MyDesignSurface" Grid.Row="0" MinHeight="100" />
        
        <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Background="{DynamicResource RiderBorderBrush}"/>
        
        <Grid Grid.Row="2" RowDefinitions="Auto, *">
            
            <Border Grid.Row="0" Background="{DynamicResource RiderPanelBrush}" BorderBrush="{DynamicResource RiderBorderBrush}" BorderThickness="0,1,0,0" Padding="5,3">
                <StackPanel Orientation="Horizontal" Spacing="15">
                    <StackPanel Orientation="Horizontal" Spacing="0">
                        <Button x:Name="BtnDesign" Content="Design" Tag="Design" Click="BtnViewMode_Click" Background="Transparent" Padding="10,2" />
                        <Button x:Name="BtnSplit" Content="Split" Tag="Split" Click="BtnViewMode_Click" Background="{DynamicResource RiderPanelBrush}" FontWeight="Bold" Padding="10,2" />
                        <Button x:Name="BtnXaml" Content="XAML" Tag="XAML" Click="BtnViewMode_Click" Background="Transparent" Padding="10,2" />
                    </StackPanel>
                    <Rectangle Width="1" Fill="{DynamicResource RiderBorderBrush}" Margin="0,2" />
                    <ComboBox x:Name="ZoomComboBox" SelectedIndex="3" Padding="10,2" MinHeight="25" SelectionChanged="ZoomComboBox_SelectionChanged">
                        <ComboBoxItem>25%</ComboBoxItem>
                        <ComboBoxItem>50%</ComboBoxItem>
                        <ComboBoxItem>100%</ComboBoxItem>
                        <ComboBoxItem>Fit to Screen</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </Border>
            
            <editor:SmartEditorView x:Name="MyCodeEditor" Grid.Row="1" MinHeight="100" />
            
        </Grid>
    </Grid>
</UserControl>