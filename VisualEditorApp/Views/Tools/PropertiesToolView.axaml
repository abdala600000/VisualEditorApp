<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="VisualEditorApp.Views.Tools.PropertiesToolView">
    <ScrollViewer>
        <ItemsControl Name="PropertiesItemsControl">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,*" Margin="2">
                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="11" Foreground="#CCCCCC" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding Value}" FontSize="11" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#555" Padding="2,1" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
