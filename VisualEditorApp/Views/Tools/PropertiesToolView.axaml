<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:VisualEditorApp.ViewModels.Tools"
             xmlns:prop="clr-namespace:VisualEditor.Toolbox.Prop;assembly=VisualEditor.Toolbox"
             mc:Ignorable="d" d:DesignWidth="260" d:DesignHeight="400"
             x:Class="VisualEditorApp.Views.Tools.PropertiesToolView"
             x:DataType="vm:PropertiesToolViewModel" x:CompileBindings="True">
    <prop:PropertiesView />
</UserControl>
