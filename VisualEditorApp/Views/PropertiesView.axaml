<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:VisualEditorApp"
             x:Class="VisualEditorApp.PropertiesView"
             x:DataType="local:PropertiesView"> <ScrollViewer>
        <ItemsControl x:Name="GroupsControl">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="local:PropertyGroup">
                    <Expander Header="{Binding Key}" IsExpanded="True" Margin="0,2">
                        
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:PropertyItem">
                                    <Grid ColumnDefinitions="120, *" Margin="2">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay}" BorderThickness="0,0,0,1"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                    </Expander>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>