<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualEditorApp.ViewModels"
             x:Class="VisualEditorApp.ProjectConfigurationView"
             x:DataType="vm:ProjectConfigurationViewModel">
             <Grid RowDefinitions="Auto,*,Auto" Margin="20">

        <Grid Grid.Row="0" ColumnDefinitions="150,*,80" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" >
            <Grid.Styles>
                <Style Selector="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="0,0,10,10"/>
                </Style>
                <Style Selector="TextBox, ComboBox">
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                </Style>
            </Grid.Styles>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Project name" />
            <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding ProjectName}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Location" />
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Location}" Margin="0,0,10,10" />
            <Button Grid.Row="1" Grid.Column="2" Content="Browse" Command="{Binding BrowseCommand}" CommandParameter="{Binding $self}" Margin="0,0,0,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Language" />
            <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" SelectedIndex="0">
                <ComboBoxItem>C#</ComboBoxItem>
            </ComboBox>

            <CheckBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Content="Create project directory" IsChecked="{Binding CreateProjectDirectory}" Margin="0,0,0,10"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Solution name" />
            <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding SolutionName}" />

            <CheckBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Content="Create solution directory" IsChecked="{Binding CreateSolutionDirectory}" Margin="0,0,0,5"/>
            <CheckBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Content="Add project to solution" IsChecked="{Binding AddProjectToSolution}" Margin="0,0,0,10"/>
            
            <CheckBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Content="Initialize a new Git repository" IsChecked="{Binding InitializeGit}" Margin="0,0,0,10"/>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto, *, Auto" Margin="0,15,0,0">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="Projects: 1" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <Button Content="Add" Padding="10,5" Margin="0,0,5,0" />
                <Button Content="Remove" Padding="10,5" />
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding ProjectsList}" AutoGenerateColumns="False" 
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Project" Binding="{Binding Name}" Width="*" />
                    <DataGridCheckBoxColumn Header="Create Directory" Binding="{Binding CreateDir}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2" Margin="0,15,0,0">
                <TextBlock Text="Project path preview" FontWeight="Bold" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding ProjectPathPreview}" Margin="0,0,0,10" TextWrapping="Wrap" Opacity="0.7"/>

                <TextBlock Text="Solution path preview" FontWeight="Bold" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding SolutionPathPreview}" TextWrapping="Wrap" Opacity="0.7"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Back" Width="80" HorizontalContentAlignment="Center" Margin="0,0,10,0"/>
            <Button Classes="accent" Content="Create" Command="{Binding CreateCommand}" Width="80" HorizontalContentAlignment="Center" Margin="0,0,10,0"/>
            <Button Content="Cancel" Width="80" HorizontalContentAlignment="Center" Command="{Binding CancelCommand}"/>
        </StackPanel>

    </Grid>
</UserControl>