<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:editor="clr-namespace:VisualEditor.CodeEditor;assembly=VisualEditor.CodeEditor"     
xmlns:avaloniaEdit="https://github.com/avaloniaui/avaloniaedit"
xmlns:designer="using:VisualEditor.Designer"
             x:Class="VisualEditorApp.WorkspaceView">

   

  <Grid RowDefinitions="*, 5, *">
        
        <designer:DesignerSurfaceView x:Name="MyDesignSurface" 
                                      DesignChanged="MyDesignSurface_DesignChanged" 
                                      SelectionChanged="MyDesignSurface_SelectionChanged" 
                                      Grid.Row="0" />

        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="Gray"/>

        <editor:SmartEditorView x:Name="MyCodeEditor" 
                                XamlTextChanged="MyCodeEditor_XamlTextChanged" 
                                Grid.Row="2" />
        
    </Grid>
</UserControl>