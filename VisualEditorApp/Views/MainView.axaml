<UserControl x:Class="VisualEditorApp.Views.MainView"
			 xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:win32="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls"
			 xmlns:vm="using:VisualEditorApp.ViewModels"
			 mc:Ignorable="d"
			 d:DesignWidth="1200" d:DesignHeight="720"
			 x:DataType="vm:MainWindowViewModel" x:CompileBindings="True"
			 Background="{DynamicResource RiderBackgroundBrush}"
			 FontFamily="JetBrains Sans, Segoe UI, Noto Sans, sans-serif">
	<Design.DataContext>
		<vm:MainWindowViewModel />
	</Design.DataContext>
	<UserControl.Resources>
		<StreamGeometry x:Key="IconOpen">M4 4H6L7 6H14V12H6L4 10V4Z</StreamGeometry>
		<StreamGeometry x:Key="IconSave">M3 3H12L14 5V13H3V3ZM5 5V7H11V5H5Z</StreamGeometry>
		<StreamGeometry x:Key="IconRun">M5 4L12 8L5 12V4Z</StreamGeometry>
		<StreamGeometry x:Key="IconBuild">M14.7,11C15.3,11 16,10.3 16,9.5C16,8.7 15.3,8 14.5,8C13.7,8 13,8.7 13,9.5C13,10.3 13.7,11 14.5,11M14.5,1C12,1 10,3 10,5.5C10,6.7 10.5,7.8 11.3,8.6L2.3,17.6C1.9,18 1.9,18.7 2.3,19.1L4.9,21.7C5.3,22.1 6,22.1 6.4,21.7L15.4,12.7C16.2,13.5 17.3,14 18.5,14C21,14 23,12 23,9.5C23,7 21,5 18.5,5C17.3,5 16.2,5.5 15.4,6.3L13.7,4.6C13.9,4.9 14,5.2 14,5.5C14,6.3 13.3,7 12.5,7C11.7,7 11,6.3 11,5.5C11,4.7 11.7,4 12.5,4C12.8,4 13.1,4.1 13.4,4.3L11.7,2.6C10.9,3.4 10.4,4.5 10.4,5.7L14.5,1.6L14.5,1Z</StreamGeometry>
	</UserControl.Resources>
	<UserControl.KeyBindings>
		<KeyBinding Gesture="F5"
					Command="{Binding RunProjectCommand}" />

		<KeyBinding Gesture="Ctrl+Shift+B"
					Command="{Binding BuildStartupProjectCommand}" />

		<KeyBinding Gesture="Ctrl+S"
					Command="{Binding SaveAllCommand}" />
	</UserControl.KeyBindings>
	<Grid RowDefinitions="Auto,Auto,*,Auto">
		<Grid Grid.Row="0"
			  ColumnDefinitions="Auto,*"
			  Background="Transparent"
			  PointerPressed="OnTitleBarPointerPressed"
			  win32:Win32Properties.NonClientHitTestResult="Caption">
			<Border Grid.ColumnSpan="2"
					Background="{DynamicResource RiderPanelBrush}"
					IsHitTestVisible="False" />
			<Menu x:Name="MainMenu"
				  Grid.Column="0"
				  Background="{x:Null}"
				  win32:Win32Properties.NonClientHitTestResult="Caption"
				  HorizontalAlignment="Left">
				<Menu.Styles>
					<Style Selector="MenuItem">
						<Setter Property="(win32:Win32Properties.NonClientHitTestResult)" Value="Client" />
					</Style>
				</Menu.Styles>
				<MenuItem Header="File">
					<MenuItem Header="New">
						<MenuItem Header="New Project..." />
						<MenuItem Header="New Solution..." Command="{Binding OpenNewProjectCommand}"  />
						<MenuItem Header="New File from Template..." />
					</MenuItem>
					<MenuItem Header="_Open Solution..." InputGesture="Ctrl+O" Click="OnOpenSolutionClicked" />
					<MenuItem Header="Open Recent" />
					<Separator Background="#333"/>
					<MenuItem Header="_Save" Command="{Binding SaveFileCommand}" InputGesture="Ctrl+S" />
					<MenuItem Header="Save _All" Command="{Binding SaveAllCommand}" InputGesture="Ctrl+Shift+S" />
					<Separator Background="#333"/>
					<MenuItem Header="Extensions" />
					<MenuItem Header="Save Mode" />
					<Separator Background="#333"/>
					<MenuItem Header="E_xit" Command="{Binding ExitCommand}" InputGesture="Alt+F4" />
				</MenuItem>
				<MenuItem Header="Edit" />
				<MenuItem Header="View" />
				<MenuItem Header="Debug" />
				<MenuItem Header="Tools" />
				<MenuItem Header="Extensions" />
				<MenuItem Header="Help" />

				<MenuItem Header="Build">
					<MenuItem Header="Build Startup Project" 
							  Command="{Binding BuildStartupProjectCommand}"
							  InputGesture="Ctrl+Shift+B">
						<MenuItem.Icon>
							<PathIcon Data="{StaticResource IconBuild}" Width="14" Height="14"/>
						</MenuItem.Icon>
					</MenuItem>
					<Separator />
					<MenuItem Header="Rebuild Startup Project" />
					<MenuItem Header="Clean Startup Project" />
				</MenuItem>

				<MenuItem Header="_View">
					<MenuItem Header="_Theme">
						<MenuItem Header="_Rider Light"
								  IsChecked="{Binding IsLightTheme, Mode=OneWay}"
								  Command="{Binding SwitchToLightThemeCommand}" />
						<MenuItem Header="_Rider Dark"
								  IsChecked="{Binding IsDarkTheme, Mode=OneWay}"
								  Command="{Binding SwitchToDarkThemeCommand}" />
					</MenuItem>
				</MenuItem>

			</Menu>
		</Grid>

		<Border Grid.Row="1"
				Background="{DynamicResource RiderPanelBrush}"
				BorderBrush="{DynamicResource RiderBorderBrush}"
				BorderThickness="0,0,0,1">
			<Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto" Margin="8,6">

				<StackPanel Orientation="Horizontal" Spacing="5">
					<Button Content="📄" Background="Transparent" ToolTip.Tip="New File"/>
					<Button Content="📂" Background="Transparent" ToolTip.Tip="Open Folder"/>
					<Button Content="💾" Background="Transparent" ToolTip.Tip="Save"/>

					<TextBlock Text="|" Foreground="#444" VerticalAlignment="Center" Margin="5,0"/>

					<Button Command="{Binding BuildStartupProjectCommand}"
							ToolTip.Tip="Build Startup Project (Ctrl+Shift+B)"
							Background="Transparent"
							BorderThickness="0">
						<PathIcon Data="{StaticResource IconBuild}"
								  Foreground="#2270CF"
								  Width="18" Height="18"/>
					</Button>

					<Button Command="{Binding RunProjectCommand}"
							ToolTip.Tip="Run Startup Project (F5)"
							Background="Transparent"
							BorderThickness="0">
						<PathIcon Data="{StaticResource IconRun}"
								  Foreground="#4CAF50"
								  Width="18" Height="18"/>
					</Button>
					<Button Content="⏹️" Background="Transparent" ToolTip.Tip="Stop"/>

					<TextBlock Text="|" Foreground="#444" VerticalAlignment="Center" Margin="5,0"/>

					<Button Content="✂️" Background="Transparent" ToolTip.Tip="Cut"/>
					<Button Content="📋" Background="Transparent" ToolTip.Tip="Copy"/>
					<Button Content="📋" Background="Transparent" ToolTip.Tip="Paste"/>
					<Button Content="🗑️" Background="Transparent" ToolTip.Tip="Delete"/>

					<TextBlock Text="|" Foreground="#444" VerticalAlignment="Center" Margin="5,0"/>

					<Button Content="New Project" Command="{Binding OpenNewProjectCommand}"
							Background="#3E3E42" Foreground="White" Padding="10,2" CornerRadius="3"/>
				</StackPanel>
				<TextBox Grid.Column="4"
						 Width="240"
						 Watermark="Search Everywhere"
						 UseFloatingWatermark="True" />
			</Grid>
		</Border>

		<DockControl Grid.Row="2" Layout="{Binding Layout}" Margin="6" />

		<Border Grid.Row="3"
				Background="{DynamicResource RiderPanelBrush}"
				BorderBrush="{DynamicResource RiderBorderBrush}"
				BorderThickness="1,1,1,0">
			<Grid ColumnDefinitions="*,Auto,Auto" Margin="10,4">
				<TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
				<TextBlock Text="{Binding SolutionName}" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" />
				<TextBlock Text="{Binding ActiveDocumentStatus}" Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center" />
			</Grid>
		</Border>
	</Grid>
</UserControl>
