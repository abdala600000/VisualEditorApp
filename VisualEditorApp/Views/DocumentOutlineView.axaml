<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tools="using:VisualEditorApp.Models.Tools"
             xmlns:models="using:VisualEditorApp.Models"
             x:Class="VisualEditorApp.DocumentOutlineView"
             x:DataType="tools:DocumentOutlineTool">

    <Grid RowDefinitions="Auto, *">
        <TextBox Grid.Row="0" Margin="5" Watermark="Search Elements..." />

        <TreeView Grid.Row="1" 
                  ItemsSource="{Binding Nodes,Mode=TwoWay}" 
                  SelectionMode="Single"
                  SelectionChanged="TreeView_SelectionChanged">
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}" DataType="{x:Type models:ElementNode}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource BoxIcon}" Width="12" Height="12" Foreground="DodgerBlue"/>
                        <TextBlock Text="{Binding Header}" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
